# ─── Client (exposed to the browser) ─────────────────────────────────
# Vite inlines anything starting with VITE_ into the client bundle.
# These two are the public Supabase project URL and anon key — safe to expose.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Server-only (Vercel serverless functions) ───────────────────────
# These never reach the client. Set them in the Vercel project's
# Environment Variables panel, NOT in this file or anywhere committed.

# Your Anthropic API key. The /api/claude proxy uses it on every authenticated
# request — clients never see it.
ANTHROPIC_API_KEY=sk-ant-...

# Supabase service role JWT. Used by the auth-gate function to verify the
# caller's Supabase JWT and re-check the email allowlist. Lives in the
# "Legacy API Keys" panel of the Supabase project settings (the long
# JWT labelled `service_role`, not the new publishable/secret key pair).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional. Per-user soft cap on /api/claude requests per 24h. Defaults to 100.
# CLAUDE_DAILY_LIMIT=100
